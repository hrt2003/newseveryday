  "source_priority": [
    "BBC World", "The Guardian", "Al Jazeera", "NPR World",
    "CNBC", "MarketWatch", "Yahoo Finance", "Investing.com",
    "TechCrunch", "The Verge", "Ars Technica", "Wired",
    "Nature", "Science Daily", "New Scientist", "Scientific American",
    "ESPN", "BBC Sport", "Sky Sports", "The Athletic",
    "Variety", "Billboard", "Deadline", "The Hollywood Reporter",
    "WHO", "Medical News Today", "STAT News", "NIH News",
    "IGN", "Kotaku", "PC Gamer", "GameSpot",
    "Autoblog", "Motor Trend", "Car and Driver", "Road & Track",
    "Inside Climate News", "Grist", "Carbon Brief", "Mongabay",
    "EdSurge", "Inside Higher Ed", "The Chronicle", "Education Week",
    "Pitchfork", "Rolling Stone", "NME", "Billboard News",
    "Skift", "The Points Guy", "Nomadic Matt", "Travel Off Path"
  ],

  "dedup": { "similarity_threshold": 0.6, "per_category": true },
  "fetch": {
    "max_articles_per_feed": 8,
    "request_timeout_seconds": 30,
    "max_retries": 2,
    "retry_backoff_factor": 2.0
  },
  "deepseek": {
    "base_url": "https://api.deepseek.com/v1",
    "model": "deepseek-chat",
    "temperature": 0.3,
    "max_tokens": 16384,
    "request_timeout_seconds": 90
  },
  "output": { "directory": "docs", "filename_template": "{date}-news-digest.md" },
  "email": { "enabled": false, "subject_template": "Daily News Digest - {date}" }
}
