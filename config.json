  "source_priority": [
    "BBC World", "The Guardian", "Al Jazeera", "NPR World", "France 24", "Deutsche Welle",
    "CNBC Top News", "MarketWatch", "NPR Business", "Yahoo Finance", "Investing.com", "The Economist",
    "TechCrunch", "The Verge", "Ars Technica", "Wired", "The Register", "Hacker News",
    "Skift", "The Points Guy", "Nomadic Matt", "Travel Off Path",
    "ESPN", "BBC Sport", "Sky Sports",
    "Science Daily", "New Scientist", "Nature",
    "Variety", "Billboard", "Deadline",
    "WHO", "Medical News Today", "STAT News",
    "IGN", "Kotaku", "PC Gamer",
    "Autoblog", "Motor Trend",
    "Inside Climate News", "Grist",
    "EdSurge", "Inside Higher Ed",
    "Pitchfork", "Rolling Stone", "NME"
  ],
  "dedup": {
    "similarity_threshold": 0.6,
    "per_category": true
  },
  "fetch": {
    "max_articles_per_feed": 8,
    "request_timeout_seconds": 30,
    "max_retries": 2,
    "retry_backoff_factor": 2.0
  },
  "deepseek": {
    "base_url": "https://api.deepseek.com/v1",
    "model": "deepseek-chat",
    "temperature": 0.3,
    "max_tokens": 16384,
    "request_timeout_seconds": 90
  },
  "output": {
    "directory": "docs",
    "filename_template": "{date}-news-digest.md"
  },
  "email": {
    "enabled": false,
    "subject_template": "Daily News Digest - {date}"
  }
}
